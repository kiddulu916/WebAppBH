# docker/Dockerfile.authz
FROM webbh-base:latest

# Copy worker code
COPY workers/authorization/ /app/workers/authorization/
COPY shared/ /app/shared/

# Install lib_webbh
RUN pip install -e /app/shared/lib_webbh

WORKDIR /app
ENV PIP_DEFAULT_TIMEOUT=300
ENV WORKER_TYPE=authorization

CMD ["python", "-m", "workers.authorization.main"]
