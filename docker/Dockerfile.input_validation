# ============================================================
# Stage 1: Go tool builder (none needed for input_validation)
# ============================================================

# ============================================================
# Stage 2: Python tool + lib_webbh builder
# ============================================================
FROM python:3.10-slim-bookworm AS py-builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --target=/py-tools \
    sqlmap

# Install lib_webbh (needs gcc + libpq-dev at compile time)
COPY shared/lib_webbh /build/lib_webbh
RUN pip install --no-cache-dir --target=/py-tools /build/lib_webbh

# ============================================================
# Stage 3: Runtime
# ============================================================
FROM python:3.10-slim-bookworm

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    libpq5 && \
    rm -rf /var/lib/apt/lists/*

# Python tools
COPY --from=py-builder /py-tools /usr/local/lib/python3.10/site-packages/

# Shared directories
RUN mkdir -p /app/shared/raw /app/shared/config /app/shared/logs

# Worker source
COPY workers/__init__.py /app/workers/__init__.py
COPY workers/input_validation /app/workers/input_validation

# Verify
RUN python -c "from workers.input_validation.main import main; print('input_validation OK')"

ENTRYPOINT ["python", "-m", "workers.input_validation.main"]