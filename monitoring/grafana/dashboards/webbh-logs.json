{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [{ "datasource": { "type": "loki" }, "expr": "sum(count_over_time({compose_service=~\".+\"}[1m])) by (compose_service)", "legendFormat": "{{compose_service}}", "refId": "A" }]
    },
    {
      "title": "Error Rate by Worker",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "datasource": { "type": "loki" }, "expr": "sum(count_over_time({level=\"error\"}[5m])) by (service)", "legendFormat": "{{service}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Warnings by Worker",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "datasource": { "type": "loki" }, "expr": "sum(count_over_time({level=\"warning\"}[5m])) by (service)", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "title": "Recent Errors",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "targets": [{ "datasource": { "type": "loki" }, "expr": "{level=\"error\"}", "refId": "A" }],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "title": "All Logs (Filterable)",
      "type": "logs",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 28 },
      "targets": [{ "datasource": { "type": "loki" }, "expr": "{compose_service=~\"$service\"} |~ \"$search\"", "refId": "A" }],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["webbh", "logs"],
  "templating": {
    "list": [
      { "name": "service", "type": "query", "datasource": { "type": "loki" }, "query": "label_values(compose_service)", "multi": true, "includeAll": true, "current": { "text": "All", "value": "$__all" } },
      { "name": "search", "type": "textbox", "current": { "text": "", "value": "" } }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "WebAppBH Logs",
  "uid": "webbh-logs"
}
