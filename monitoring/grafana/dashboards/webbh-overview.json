{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Active Workers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "webbh_active_workers", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 15 }, { "color": "red", "value": 25 }] } } }
    },
    {
      "title": "Total Targets",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "webbh_targets_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "title": "Vulnerabilities Found (Rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "sum(rate(webbh_vulns_found_total[5m])) by (severity)", "legendFormat": "{{severity}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "webbh_queue_depth", "legendFormat": "{{queue}}", "refId": "A" }]
    },
    {
      "title": "Vulns by Severity (Total)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 4 },
      "targets": [{ "expr": "sum(webbh_vulns_found_total) by (severity)", "legendFormat": "{{severity}}", "refId": "A" }]
    },
    {
      "title": "Tasks Processed by Worker",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 4, "x": 4, "y": 4 },
      "targets": [{ "expr": "sum(webbh_worker_tasks_processed_total) by (worker_type)", "legendFormat": "{{worker_type}}", "refId": "A" }]
    },
    {
      "title": "API Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(webbh_api_latency_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "{{endpoint}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total{name=~\"webbh-.*\"}[1m]) * 100", "legendFormat": "{{name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{ "expr": "container_memory_usage_bytes{name=~\"webbh-.*\"} / 1024 / 1024", "legendFormat": "{{name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 20 },
      "targets": [{ "expr": "pg_stat_activity_count", "legendFormat": "active", "refId": "A" }]
    },
    {
      "title": "Redis Memory Used",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 20 },
      "targets": [{ "expr": "redis_memory_used_bytes / 1024 / 1024", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["webbh"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "WebAppBH Overview",
  "uid": "webbh-overview"
}
